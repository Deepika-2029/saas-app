{
  "name": "saas-backend",
  "version": "1.0.0",
  "description": "MERN SaaS Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFiles": [
      "./tests/setup.js"
    ],
    "collectCoverageFrom": [
      "services/**/*.js",
      "middleware/**/*.js",
      "models/**/*.js",
      "controllers/**/*.js",
      "utils/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 60,
        "functions": 60
      }
    },
    "testTimeout": 30000
  },
  "dependencies": {
    "@sentry/node": "^8.0.0",
    "@sentry/profiling-node": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.1",
    "ioredis": "^5.3.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.1",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.7",
    "stripe": "^14.5.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "node-mocks-http": "^1.14.1",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
